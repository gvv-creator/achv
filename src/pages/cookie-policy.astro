---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cookie Policy | ACHV Ltd."
  description="Cookie Policy for ACHV Ltd."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-5xl font-semibold">Cookie Policy</h1>
      <div class="mt-10 space-y-6 leading-8 text-black/70">
        <p>This website may use cookies or similar technologies to improve functionality, measure performance and understand website traffic.</p>
        <p>If analytics tools are added, this policy should be updated to identify those tools and explain how users can manage consent.</p>
      </div>
    </div>
  </section>
</BaseLayout>
