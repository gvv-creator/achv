---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cookie Policy | ACHV Ltd."
  description="Cookie Policy for ACHV Ltd., covering website functionality, performance and analytics technologies if added."
>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-5xl font-semibold">Cookie Policy</h1>
      <div class="mt-10 space-y-6 leading-8 text-black/70">
        <p>This website may use cookies or similar technologies to improve functionality, measure performance, understand website traffic and support advertising measurement.</p>
        <p>ACHV may use Google Analytics and Meta Pixel technologies to measure visits, page views and campaign performance. You can accept or reject optional analytics and advertising cookies in the website banner, reopen Cookie Settings from the footer, or manage cookies through your browser settings and available platform opt-out controls.</p>
      </div>
    </div>
  </section>
</BaseLayout>
