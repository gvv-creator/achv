---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Thank You | ACHV Ltd."
  description="ACHV has received your project enquiry and will review the information submitted."
  robots="noindex, follow"
>
  <section class="flex min-h-[70vh] items-center px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">Enquiry received</p>
      <h1 class="mt-5 text-5xl font-semibold">
        Thank you — your enquiry has been received.
      </h1>
      <p class="mt-6 text-lg leading-8 text-black/65">
        ACHV has received your project enquiry. Our team will review the information and respond as soon as possible.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <Button href="/">Back to Home</Button>
        <Button href="/projects" variant="outline">View Projects</Button>
      </div>
    </div>
  </section>
</BaseLayout>
