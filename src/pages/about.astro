---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";

const reasons = [
  ["Design-aware delivery", "We protect design intent while managing buildability, procurement, programme and site realities."],
  ["Clear accountability", "Clients have one project structure connecting planning, contractors, construction decisions and handover."],
  ["Site coordination discipline", "ACHV focuses on sequencing, reporting, logistics, quality control and practical delivery constraints."],
  ["Finishing detail", "The final stage is managed with attention to surfaces, junctions, materials, snagging and the completed experience."],
  ["Malta and EU27 capability", "ACHV operates from Malta and supports selected EU27 projects through structured project control and coordination."],
];
---

<BaseLayout
  title="About ACHV Ltd. | Malta Construction & Project Delivery"
  description="ACHV Ltd. is a Birkirkara, Malta-based design-led project management, construction, civil works and finishes company operating across Malta and the EU27."
  pageType="AboutPage"
>
  <section class="bg-[#161616] px-6 py-28 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">About ACHV</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight md:text-7xl">
        We exist to build better — from design vision to completed space.
      </h1>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-16 md:grid-cols-2">
      <div>
        <h2 class="text-4xl font-semibold tracking-tight">More than project management.</h2>
      </div>
      <div class="space-y-6 text-lg leading-9 text-black/65">
        <p>
          ACHV has evolved beyond project management into a full project delivery company working across project management, construction and finishes.
        </p>
        <p>
          Our strength is connecting design ambition with real-world execution. We help clients move from vision and design into controlled construction, detailed finishing and final handover.
        </p>
        <p>
          We operate from Malta with the capability to support projects across the EU27.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-16 md:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-[#b08a57]">Why ACHV</p>
        <h2 class="text-4xl font-semibold tracking-tight">
          Good design only becomes valuable when delivery is controlled.
        </h2>
        <p class="mt-6 text-lg leading-8 text-black/65">
          ACHV connects ambition, planning, construction realities and finishing standards into one accountable project structure.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {reasons.map(([title, text]) => (
          <article class="rounded-3xl border border-black/10 bg-[#f7f4ef] p-6">
            <h3 class="text-xl font-semibold">{title}</h3>
            <p class="mt-3 leading-7 text-black/65">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
