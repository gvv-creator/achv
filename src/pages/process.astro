---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";

const steps = [
  ["Vision", "We understand the client’s ambitions, desired outcome, constraints and commercial priorities."],
  ["Design coordination", "We align design intent with buildability, budget, procurement and site execution."],
  ["Planning", "We structure the project programme, responsibilities, procurement route and reporting cadence."],
  ["Construction", "We coordinate contractors, site works, technical decisions, quality control and progress."],
  ["Finishes", "We manage the details that define the final experience: surfaces, junctions, materials, lighting, bathrooms, kitchens and final snagging."],
  ["Handover", "We close the project properly, ensuring the space is ready, documented and complete."],
];

const processSchema = [
  {
    "@type": "HowTo",
    name: "ACHV design-to-completion project delivery process",
    description:
      "A structured project management, construction and finishes process from client vision to handover.",
    step: steps.map(([title, text], index) => ({
      "@type": "HowToStep",
      position: index + 1,
      name: title,
      text,
    })),
  },
];
---

<BaseLayout
  title="Design-to-Completion Construction Process Malta | ACHV Ltd."
  description="ACHV manages projects from design vision to completed space through structured project management, construction, civil works and finishing controls."
  schema={processSchema}
>
  <section class="bg-[#161616] px-6 py-28 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">Process</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight md:text-7xl">
        From dream to design. From design to completion.
      </h1>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-5xl space-y-8">
      {steps.map(([title, text], index) => (
        <article class="grid gap-6 rounded-3xl border border-black/10 bg-white p-8 md:grid-cols-[120px_1fr]">
          <p class="text-5xl font-semibold text-[#b08a57]">{String(index + 1).padStart(2, "0")}</p>
          <div>
            <h2 class="text-3xl font-semibold">{title}</h2>
            <p class="mt-4 text-lg leading-8 text-black/65">{text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTASection />
</BaseLayout>
