---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CTASection from "../components/CTASection.astro";
import { company } from "../data/company";
import { projects } from "../data/projects";

const projectSchema = [
  {
    "@type": "ItemList",
    name: "ACHV selected project portfolio",
    itemListElement: projects.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "CreativeWork",
        name: project.title,
        url: `${company.website}/projects#${project.slug}`,
        image: new URL(project.image, company.website).href,
        description: project.summary,
        contentLocation: {
          "@type": "Place",
          name: project.location,
        },
        about: project.services,
      },
    })),
  },
];
---

<BaseLayout
  title="ACHV Projects | Civil Works, Fit-Out & Restoration Malta"
  description="Explore ACHV project work across project management, construction, civil works, finishes, fit-out, infrastructure and restoration projects in Malta."
  schema={projectSchema}
>
  <section class="bg-[#161616] px-6 py-28 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">Projects</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight md:text-7xl">
        Proof of delivery, not empty claims.
      </h1>
      <p class="mt-8 max-w-2xl text-xl leading-9 text-white/70">
        ACHV’s project portfolio presents the scope, client environment, challenge, solution and outcome behind selected delivery work.
      </p>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="Selected work"
        title="Selected project portfolio"
        text="Project examples across management, construction, finishes and constrained delivery environments."
      />

      <div class="mt-14 grid gap-8 md:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
