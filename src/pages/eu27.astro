---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import CTASection from "../components/CTASection.astro";
---

<BaseLayout
  title="EU27 Project Delivery from Malta | ACHV Ltd."
  description="ACHV supports EU27 project management, procurement coordination, contractor management and design-to-completion construction delivery from Malta."
>
  <section class="bg-[#161616] px-6 py-28 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">EU27 Delivery</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight md:text-7xl">
        Malta-based. Internationally capable.
      </h1>
      <p class="mt-8 max-w-2xl text-xl leading-9 text-white/70">
        ACHV supports selected EU27 projects through Malta-based project control, procurement coordination, contractor alignment and structured reporting.
      </p>
      <div class="mt-10">
        <Button href="/contact" variant="light">Discuss an EU27 project</Button>
      </div>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-3">
      {[
        ["Cross-border coordination", "Malta-based project control for selected projects involving multiple stakeholders, suppliers or delivery locations."],
        ["Procurement and supplier alignment", "Coordination of suppliers, materials and procurement routes where international delivery needs clear responsibilities."],
        ["Reporting and delivery control", "Structured reporting, contractor alignment and delivery oversight connecting design, site works and handover."]
      ].map(([title, text]) => (
        <article class="rounded-3xl border border-black/10 bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold">{title}</h2>
          <p class="mt-4 leading-7 text-black/65">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <CTASection />
</BaseLayout>
