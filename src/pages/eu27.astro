---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
---

<BaseLayout
  title="EU27 Project Delivery from Malta | ACHV Ltd."
  description="ACHV supports project management, construction coordination and design-to-completion delivery across Malta and the EU27."
>
  <section class="bg-[#161616] px-6 py-28 text-white">
    <div class="mx-auto max-w-7xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">EU27 Delivery</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-tight md:text-7xl">
        Malta-based. Internationally capable.
      </h1>
      <p class="mt-8 max-w-2xl text-xl leading-9 text-white/70">
        ACHV supports clients with cross-border project management, procurement coordination, contractor management and project delivery across Malta and selected EU27 markets.
      </p>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-3">
      {[
        ["Cross-border coordination", "Structured reporting, stakeholder alignment and delivery control across jurisdictions."],
        ["Procurement support", "Coordination of suppliers, materials and procurement routes for international projects."],
        ["Delivery accountability", "One project structure connecting design, contractors, site works and handover."]
      ].map(([title, text]) => (
        <article class="rounded-3xl border border-black/10 bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold">{title}</h2>
          <p class="mt-4 leading-7 text-black/65">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <CTASection />
</BaseLayout>
