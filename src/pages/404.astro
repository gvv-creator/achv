---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Page Not Found | ACHV Ltd."
  description="The requested page could not be found."
>
  <section class="flex min-h-[70vh] items-center px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[#b08a57]">404</p>
      <h1 class="mt-5 text-5xl font-semibold">This page could not be found.</h1>
      <p class="mt-6 text-lg text-black/65">Return to the homepage or contact ACHV to discuss your project.</p>
      <div class="mt-10">
        <Button href="/">Back to Home</Button>
      </div>
    </div>
  </section>
</BaseLayout>
