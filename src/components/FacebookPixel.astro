---
const FACEBOOK_PIXEL_ID = "1317041353714646";
---

<script is:inline define:vars={{ FACEBOOK_PIXEL_ID }}>
  (() => {
    const hasMarketingConsent = () =>
      window.achvConsent?.read()?.marketing === true;

    const loadPixel = () => {
      if (window.achvFacebookPixelLoaded) {
        window.fbq?.("consent", "grant");
        return;
      }

      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version="2.0";
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,"script",
      "https://connect.facebook.net/en_US/fbevents.js");

      window.achvFacebookPixelLoaded = true;
      fbq("consent", "grant");
      fbq("init", FACEBOOK_PIXEL_ID);
      fbq("track", "PageView");
    };

    window.addEventListener("achv:consent-change", (event) => {
      if (event.detail?.marketing) {
        loadPixel();
        return;
      }

      window.fbq?.("consent", "revoke");
    });

    if (hasMarketingConsent()) {
      loadPixel();
    }
  })();
</script>
