---
interface Props {
  title: string;
  summary: string;
  deliverables: string[];
  bestFor?: string;
  projectHref?: string;
  projectLabel?: string;
}

const {
  title,
  summary,
  deliverables,
  bestFor,
  projectHref,
  projectLabel = "View related project",
} = Astro.props;
---

<article class="flex h-full flex-col rounded-3xl border border-black/10 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-md focus-within:-translate-y-1 focus-within:shadow-md motion-reduce:transition-none">
  <h3 class="text-2xl font-semibold">{title}</h3>
  <p class="mt-4 leading-7 text-black/65">{summary}</p>

  {
    bestFor && (
      <p class="mt-5 border-l-2 border-[#b08a57] pl-4 text-sm leading-6 text-black/65">
        <span class="font-semibold text-[#161616]">Typical scope: </span>
        {bestFor}
      </p>
    )
  }

  <ul class="mt-6 space-y-3 text-sm text-black/70">
    {
      deliverables.map((item) => (
      <li class="flex gap-3">
        <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#b08a57]" aria-hidden="true" />
        <span>{item}</span>
      </li>
      ))
    }
  </ul>

  {
    projectHref && (
      <a
        href={projectHref}
        class="mt-8 inline-flex text-sm font-semibold text-[#161616] underline decoration-[#b08a57]/40 underline-offset-4 transition hover:text-[#b08a57] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]"
      >
        {projectLabel}
      </a>
    )
  }
</article>
