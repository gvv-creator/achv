---
interface Props {
  title: string;
  summary: string;
  deliverables: string[];
}

const { title, summary, deliverables } = Astro.props;
---

<article class="rounded-3xl border border-black/10 bg-white p-8 shadow-sm">
  <h3 class="text-2xl font-semibold">{title}</h3>
  <p class="mt-4 leading-7 text-black/65">{summary}</p>

  <ul class="mt-6 space-y-3 text-sm text-black/70">
    {
      deliverables.map((item) => (
        <li class="flex gap-3">
          <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#b08a57]" />
          <span>{item}</span>
        </li>
      ))
    }
  </ul>
</article>
