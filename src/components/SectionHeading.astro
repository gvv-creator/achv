---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-[#b08a57]">{eyebrow}</p>}
  <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">{title}</h2>
  {text && <p class="mt-5 text-lg leading-8 text-black/65">{text}</p>}
</div>
