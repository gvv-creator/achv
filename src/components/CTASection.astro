---
import Button from "./Button.astro";
---

<section class="bg-[#1f2a24] px-6 py-24 text-white">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-[#d8d0c3]">Start your project</p>
      <h2 class="text-4xl font-semibold tracking-tight md:text-6xl">
        Have a project in mind? Let’s build it properly.
      </h2>
      <p class="mt-6 text-lg leading-8 text-white/70">
        Tell us what you are planning. ACHV will review the scope and advise on the right route from design to delivery.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button href="/contact" variant="light">Request a Project Review</Button>
        <Button href="https://wa.me/35679360306" variant="light">Message on WhatsApp</Button>
      </div>
    </div>
  </div>
</section>
