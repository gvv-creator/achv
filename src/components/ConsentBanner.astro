<div
  data-consent-banner
  hidden
  role="dialog"
  aria-labelledby="consent-banner-title"
  aria-describedby="consent-banner-description"
  class="fixed inset-x-0 bottom-0 z-[100] px-4 pb-4 md:px-6 md:pb-6"
>
  <div class="mx-auto max-w-5xl rounded-2xl border border-white/10 bg-[#161616] p-5 text-white shadow-2xl md:flex md:items-center md:justify-between md:gap-8">
    <div class="max-w-3xl">
      <p id="consent-banner-title" class="text-sm font-semibold uppercase tracking-[0.2em] text-[#b08a57]">
        Privacy preferences
      </p>
      <p id="consent-banner-description" class="mt-3 text-sm leading-6 text-white/75">
        We use Google Analytics and Meta Pixel to measure visits, understand campaign performance and improve our website. You can accept or reject optional analytics and advertising cookies.
      </p>
      <a href="/cookie-policy" class="mt-3 inline-flex text-sm font-semibold text-white underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">
        Cookie Policy
      </a>
    </div>

    <div class="mt-5 flex flex-col gap-3 sm:flex-row md:mt-0 md:shrink-0">
      <button
        type="button"
        data-consent-reject
        class="rounded-full border border-white/25 px-5 py-3 text-sm font-semibold text-white transition hover:border-white hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]"
      >
        Reject optional
      </button>
      <button
        type="button"
        data-consent-accept
        class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-[#161616] transition hover:bg-[#d8d0c3] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]"
      >
        Accept all
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const banner = document.querySelector("[data-consent-banner]");
    const acceptButton = banner?.querySelector("[data-consent-accept]");
    const rejectButton = banner?.querySelector("[data-consent-reject]");
    const settingsButtons = document.querySelectorAll("[data-consent-settings]");
    let returnFocusTarget = null;

    if (!banner || !acceptButton || !rejectButton || !window.achvConsent) {
      return;
    }

    const showBanner = (trigger) => {
      returnFocusTarget = trigger instanceof HTMLElement ? trigger : null;
      banner.hidden = false;
      banner.querySelector("button")?.focus({ preventScroll: true });
    };

    const hideBanner = () => {
      banner.hidden = true;
      returnFocusTarget?.focus({ preventScroll: true });
      returnFocusTarget = null;
    };

    acceptButton.addEventListener("click", () => {
      window.achvConsent.save({ analytics: true, marketing: true });
      hideBanner();
    });

    rejectButton.addEventListener("click", () => {
      window.achvConsent.save({ analytics: false, marketing: false });
      hideBanner();
    });

    settingsButtons.forEach((button) => {
      button.addEventListener("click", () => showBanner(button));
    });

    if (!window.achvConsent.read()) {
      showBanner();
    }

    banner.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        hideBanner();
      }
    });
  })();
</script>
