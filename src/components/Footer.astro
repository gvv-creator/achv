---
import { company } from "../data/company";
import { navigation } from "../data/navigation";
---

<footer class="bg-[#161616] text-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 md:grid-cols-5">
    <div class="md:col-span-2">
      <img
        src={company.logos.white}
        alt="ACHV Ltd."
        width="140"
        height="40"
        class="h-10 w-auto"
      />
      <p class="mt-4 max-w-md text-white/70">
        Design-led project management, construction and finishes from design stage to completion across Malta and the EU27.
      </p>
    </div>

    <div>
      <p class="font-semibold">Contact</p>
      <div class="mt-4 space-y-2 text-sm text-white/70">
        <p>{company.email}</p>
        <a href={`tel:${company.tel}`} class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">{company.phone}</a>
        <p>{company.location}</p>
      </div>
    </div>

    <div>
      <p class="font-semibold">Explore</p>
      <div class="mt-4 space-y-2 text-sm text-white/70">
        {
          navigation.map((item) => (
            <a
              href={item.href}
              class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>

    <div>
      <p class="font-semibold">Legal</p>
      <div class="mt-4 space-y-2 text-sm text-white/70">
        <a href="/privacy-policy" class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">Privacy Policy</a>
        <a href="/cookie-policy" class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">Cookie Policy</a>
        <button type="button" data-consent-settings class="block text-left transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">
          Cookie Settings
        </button>
      </div>

      <p class="mt-8 font-semibold">Social</p>
      <div class="mt-4 space-y-2 text-sm text-white/70">
        <a href={company.social.facebook} target="_blank" rel="noopener noreferrer" class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">Facebook</a>
        <a href={company.social.instagram} target="_blank" rel="noopener noreferrer" class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">Instagram</a>
        <a href={company.social.linkedin} target="_blank" rel="noopener noreferrer" class="block transition hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]">LinkedIn</a>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 px-6 py-6 text-center text-sm text-white/50">
    © {new Date().getFullYear()} ACHV Ltd. All rights reserved.
  </div>
</footer>
