---
interface Props {
  title: string;
  location: string;
  sector: string;
  services: string[];
  image: string;
  summary: string;
}

const { title, location, sector, services, image, summary } = Astro.props;
---

<article class="overflow-hidden rounded-3xl border border-black/10 bg-white shadow-sm">
  <img src={image} alt={title} class="h-80 w-full object-cover" />

  <div class="p-7">
    <div class="flex flex-wrap gap-2">
      <span class="rounded-full bg-[#f7f4ef] px-3 py-1 text-xs font-semibold uppercase tracking-wide">
        {sector}
      </span>
      <span class="rounded-full bg-[#f7f4ef] px-3 py-1 text-xs font-semibold uppercase tracking-wide">
        {location}
      </span>
    </div>

    <h3 class="mt-5 text-2xl font-semibold">{title}</h3>
    <p class="mt-4 leading-7 text-black/65">{summary}</p>

    <div class="mt-5 flex flex-wrap gap-2">
      {
        services.map((service) => (
          <span class="text-sm text-[#b08a57]">{service}</span>
        ))
      }
    </div>
  </div>
</article>
