---
interface Props {
  title: string;
  location: string;
  sector: string;
  services: string[];
  image: string;
  summary: string;
  slug?: string;
  challenge?: string;
  solution?: string;
  outcome?: string;
  categories?: string[];
}

const {
  title,
  location,
  sector,
  services,
  image,
  summary,
  slug,
  challenge,
  solution,
  outcome,
  categories = [],
} = Astro.props;
const imageAlt = `${title} project in ${location}: ${sector}`;
const cardId = slug ?? title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
const detailsId = `${cardId}-details`;
const primaryService = services[0] ?? sector;
const searchText = [title, location, sector, summary, ...services].join(" ").toLowerCase();
const visibleDetails = [
  ["Location", location],
  ["Sector", sector],
  ["Scope", services.join(", ")],
  ["Delivery challenge", challenge],
  ["ACHV role", solution],
  ["Outcome", outcome],
].filter(([, value]) => value && String(value).trim().length > 0);
---

<article
  id={slug}
  data-project-card
  data-project-categories={categories.join("|")}
  data-project-search={searchText}
  class="group overflow-hidden rounded-3xl border border-black/10 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-xl focus-within:-translate-y-1 focus-within:shadow-xl motion-reduce:transition-none"
>
  <div class="relative overflow-hidden bg-[#161616]">
    <img
      src={image}
      alt={imageAlt}
      width="1200"
      height="900"
      class="aspect-[4/3] h-auto w-full object-cover transition duration-300 group-hover:scale-[1.02] group-focus-within:scale-[1.02] motion-reduce:transition-none"
      loading="lazy"
      decoding="async"
    />

    <div class="pointer-events-none absolute inset-0 hidden bg-[#161616]/92 p-6 text-white opacity-0 transition duration-200 group-hover:opacity-100 group-focus-within:opacity-100 motion-reduce:transition-none md:flex md:flex-col">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#b08a57]">
        Project details
      </p>
      <h3 class="mt-3 text-2xl font-semibold leading-tight">{title}</h3>
      <p class="mt-3 text-sm leading-6 text-white/70">{summary}</p>

      <dl class="mt-5 space-y-3 overflow-y-auto pr-1 text-sm">
        {
          visibleDetails.map(([label, value]) => (
            <div>
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-white/45">
                {label}
              </dt>
              <dd class="mt-1 leading-6 text-white/82">{value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>

  <div class="p-7">
    <div class="flex flex-wrap gap-2">
      <span class="rounded-full bg-[#f7f4ef] px-3 py-1 text-xs font-semibold uppercase tracking-wide">
        {primaryService}
      </span>
      <span class="rounded-full bg-[#f7f4ef] px-3 py-1 text-xs font-semibold uppercase tracking-wide">
        {location}
      </span>
    </div>

    <h3 class="mt-5 text-2xl font-semibold">{title}</h3>
    <p class="mt-4 leading-7 text-black/65">{summary}</p>

    <div class="mt-5 flex flex-wrap gap-2">
      {
        services.map((service) => (
          <span class="text-sm text-[#b08a57]">{service}</span>
        ))
      }
    </div>

    <button
      type="button"
      data-project-toggle
      aria-expanded="false"
      aria-controls={detailsId}
      class="mt-7 inline-flex min-h-11 items-center rounded-full border border-black/10 px-4 py-2 text-sm font-semibold text-[#161616] transition hover:border-[#161616] hover:bg-[#161616] hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#b08a57]"
    >
      Project details
      <span class="sr-only"> for {title}</span>
    </button>

    <div
      id={detailsId}
      data-project-details
      hidden
      class="mt-6 border-t border-black/10 pt-6"
    >
      <dl class="space-y-4 text-sm">
        {
          visibleDetails.map(([label, value]) => (
            <div>
              <dt class="font-semibold text-[#161616]">{label}</dt>
              <dd class="mt-1 leading-6 text-black/65">{value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</article>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const button = target.closest("[data-project-toggle]");

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const controls = button.getAttribute("aria-controls");
    const panel = controls ? document.getElementById(controls) : null;

    if (!panel) {
      return;
    }

    const isExpanded = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", String(!isExpanded));
    panel.hidden = isExpanded;
  });
</script>
