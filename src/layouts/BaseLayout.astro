---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ConsentMode from "../components/ConsentMode.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import GoogleTagManager from "../components/GoogleTagManager.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import FacebookPixel from "../components/FacebookPixel.astro";
import { company } from "../data/company";

interface Props {
  title: string;
  description: string;
  robots?: string;
  pageType?: string | string[];
  schema?: Record<string, unknown>[];
}

const {
  title,
  description,
  robots = "index, follow",
  pageType = "WebPage",
  schema = [],
} = Astro.props;
const siteUrl = company.website;
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL("/images/brand/achv-og-image.jpg", siteUrl).href;
const ogImageAlt = `${company.name} logo on dark background`;
const organizationId = new URL("/#organization", siteUrl).href;
const websiteId = new URL("/#website", siteUrl).href;
const webpageId = `${canonical}#webpage`;
const breadcrumbId = `${canonical}#breadcrumb`;
const pageName = title.split("|")[0].trim();
const address = {
  "@type": "PostalAddress",
  streetAddress: company.address.streetAddress,
  addressLocality: company.address.addressLocality,
  addressCountry: company.address.addressCountry,
};
const areaServed = [
  { "@type": "Country", name: "Malta" },
  { "@type": "AdministrativeArea", name: "European Union" },
];
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: new URL("/", siteUrl).href,
  },
  ...(Astro.url.pathname === "/"
    ? []
    : [
        {
          "@type": "ListItem",
          position: 2,
          name: pageName,
          item: canonical,
        },
      ]),
];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization", "LocalBusiness", "ProfessionalService"],
      "@id": organizationId,
      name: company.name,
      legalName: company.name,
      slogan: company.slogan,
      url: company.website,
      logo: {
        "@type": "ImageObject",
        url: new URL(company.logos.fullColour, siteUrl).href,
      },
      image: ogImage,
      email: company.email,
      telephone: company.phone,
      address,
      areaServed,
      sameAs: Object.values(company.social),
      description: company.positioning,
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: company.website,
      name: company.name,
      description: company.positioning,
      inLanguage: "en-MT",
      publisher: {
        "@id": organizationId,
      },
    },
    {
      "@type": pageType,
      "@id": webpageId,
      url: canonical,
      name: pageName,
      headline: pageName,
      description,
      isPartOf: {
        "@id": websiteId,
      },
      publisher: {
        "@id": organizationId,
      },
      breadcrumb: {
        "@id": breadcrumbId,
      },
      inLanguage: "en-MT",
    },
    {
      "@type": "BreadcrumbList",
      "@id": breadcrumbId,
      itemListElement: breadcrumbItems,
    },
    ...schema,
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <ConsentMode />
    <GoogleTagManager />

    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href={company.logos.fullColour} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={company.name} />
    <meta property="og:locale" content="en_MT" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1565" />
    <meta property="og:image:height" content="1103" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
    <GoogleAnalytics />
    <FacebookPixel />
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MKDTXDS6"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-white focus:px-5 focus:py-3 focus:text-sm focus:font-semibold focus:text-[#161616] focus:shadow-lg"
    >
      Skip to content
    </a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />
  </body>
</html>
